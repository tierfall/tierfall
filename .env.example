# TierFall - root env example. Mirrors apps/demo-cli/.env.example so root-level
# scripts and integration tests can read keys from a single location.
# All values are optional - the demo runs against Ollama only if these are absent.

# Anthropic (premium-cloud tier)
ANTHROPIC_API_KEY=

# OpenAI (premium-cloud tier via openai-compatible adapter)
OPENAI_API_KEY=

# DeepSeek (cheap-cloud tier via openai-compatible adapter)
DEEPSEEK_API_KEY=

# Ollama (on-device tier) - override when running outside Compose (e.g. host install)
OLLAMA_BASE_URL=http://localhost:11434
